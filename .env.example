# Postgres (used by docker-compose)
POSTGRES_DB=taxonomy
POSTGRES_USER=taxonomy
POSTGRES_PASSWORD=taxonomy

# Host access (used by local scripts and Python library)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taxonomy
DB_USER=taxonomy
DB_PASSWORD=taxonomy

# Embeddings — must match the vector(N) dimension in 00_init.sql
# all-MiniLM-L6-v2 outputs 384 dimensions (default)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# LLM provider: ollama | anthropic | openai
LLM_PROVIDER=ollama

# Ollama (local, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Anthropic Claude (requires API key)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (requires API key)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ingestion defaults (can be overridden per experiment)
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=50
DEFAULT_CHUNKER=naive
